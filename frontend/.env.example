# Clave publica de Clerk usada por el flujo de inicio de sesion del frontend.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_replace_me

# URL publica opcional de la API para futuros despliegues.
# En desarrollo local la app usa el proxy de Vite desde /api hacia http://localhost:3002.
# VITE_API_URL solo aplica si cambias api.ts a usarla; el proxy es /api por defecto.
VITE_API_URL=http://localhost:3002

# PostHog error tracking del frontend. Deja vacio para desactivar en desarrollo.
VITE_POSTHOG_PROJECT_TOKEN=phc_replace_me
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Cloud name de Cloudinary para CDN de imagenes: fetch-transform de URLs externas y delivery
# optimizado (f_auto,q_auto,w_) de las imagenes propias subidas/migradas a Cloudinary. Vacío =
# URLs sin optimizar/transformar. Mismo cloud name que CLOUDINARY_CLOUD_NAME en backend/.env.
VITE_CLOUDINARY_CLOUD_NAME=
