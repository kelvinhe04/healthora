# Cadena de conexion de MongoDB Atlas usada por el backend.
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?appName=Healthora-Cluster

# Nombre de la base de datos dentro del cluster de MongoDB.
MONGODB_DB_NAME=healthora

# Clave secreta de Clerk usada por el backend para verificar sesiones y gestionar usuarios.
CLERK_SECRET_KEY=sk_test_replace_me

# Clave secreta de Stripe usada para crear sesiones de checkout.
STRIPE_SECRET_KEY=sk_test_replace_me

# Secreto del webhook de Stripe usado por /webhooks para verificar checkout.session.completed.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Puerto del backend.
PORT=3001

# Origen del frontend permitido por CORS (un solo origen).
FRONTEND_URL=http://localhost:5173

# Varios orígenes separados por coma (staging + previews Vercel). Tiene prioridad sobre FRONTEND_URL.
# CORS_ORIGINS=http://localhost:5173,https://preview.vercel.app

# Entorno lógico: development | staging | production
APP_ENV=development

# Clave publica JWT opcional de Clerk. Dejala vacia salvo que tu configuracion la requiera.
CLERK_JWT_KEY=

# Correos admin separados por coma que se inicializan como admin al iniciar sesion.
ADMIN_EMAILS=tu-correo@dominio.com

# Credenciales de Cloudinary para subir imagenes (upload del admin, fotos de devolucion, imagenes
# de variante via MCP). Sin estas 3 variables, cualquier intento de subir una imagen falla - no hay
# fallback a disco local. Cloud name, API key y API secret estan en tu dashboard de Cloudinary
# (Settings > API Keys).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Rate limiting opcional. Defaults: 60s, 300 requests por IP, 120 requests por usuario autenticado.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_IP_MAX=300
RATE_LIMIT_USER_MAX=120

# Umbrales APM usados por el panel de rendimiento.
APM_SLOW_REQUEST_MS=1000
APM_P95_ALERT_MS=1500
APM_ERROR_RATE_ALERT_PERCENT=5

# PostHog error tracking. Activa captura de excepciones del backend si se define.
POSTHOG_PROJECT_API_KEY=phc_replace_me
POSTHOG_HOST=https://us.i.posthog.com

# PostHog Query API (panel admin de Analítica de producto, HU-054). Distintas credenciales a las
# de arriba: POSTHOG_PROJECT_API_KEY es la clave de solo-escritura para enviar eventos, esta clave
# personal es de solo-lectura para consultarlos de vuelta. Sin estas 2 variables el panel muestra
# el embudo en cero (configured: false) en vez de fallar. Genera la clave personal en
# https://us.posthog.com/settings/user-api-keys (scope "query:read"); el project id numerico esta
# en Project settings > General.
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=

# Redis opcional para cache de catálogo. Sin URL usa memoria del proceso.
REDIS_URL=
CACHE_TTL_SEC=60

# Token de servicio para el servidor MCP (POST /mcp). Genera uno con `openssl rand -hex 32` -
# es el mismo valor que pegas como Authorization: Bearer <token> en la config de Claude Code /
# Codex / conectores de ChatGPT. Sin esta variable, /mcp responde 503. Ver docs/mcp-server.md.
MCP_SERVICE_TOKEN=

# SMTP para correos transaccionales (confirmacion de pedido, cambio de estado, newsletter).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-cuenta@gmail.com
SMTP_PASS=

# Remitente (header From). IMPORTANTE: si no defines esta variable, el codigo cae a
# `Healthora <SMTP_USER>` - usa ese mismo dominio salvo que tengas SPF/DKIM configurados para
# autorizar a SMTP_USER a enviar en nombre de otro dominio. Un From con un dominio distinto al de
# la cuenta autenticada es una señal clasica de spam/spoofing (ver issue #171).
SMTP_FROM=Healthora <tu-cuenta@gmail.com>
